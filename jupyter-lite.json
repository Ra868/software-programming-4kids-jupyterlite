{
  "jupyter-lite-schema-version": 0,
  "litePluginSettings": {
    "@jupyterlite/pyodide-kernel-extension:kernel": {
      "enable": true
    }
  },
  "jupyter": {
    "notebook": {
      "defaultKernelName": "pyodide"
    }
  },
  "@jupyterlab/toc:plugin": {
    "showToc": true,
    "showToolbarButton": false
  },
  "@jupyterlab/apputils-extension:themes": {
    "theme": "JupyterLab Light"
  }
}
