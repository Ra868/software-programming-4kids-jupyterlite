{
  "jupyter-lite-schema-version": 0,
  "jupyter": {
    "notebook": {
      "requiredKernels": ["pyodide"],
      "defaultKernelName": "pyodide"
    }
  },
  "litePluginSettings": {
    "@jupyterlite/pyodide-kernel-extension:kernel": {
      "pyodideUrl": "https://cdn.jsdelivr.net/pyodide/v0.23.4/full/"
    }
  }
}
